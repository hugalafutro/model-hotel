{
	"name": "web",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"dev": "vite",
		"build": "tsc -b && vite build",
		"build:docker": "vite build",
		"typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
		"lint": "eslint ${@:-.}",
