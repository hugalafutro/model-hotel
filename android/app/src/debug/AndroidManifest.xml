<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only overlay: a dev Front Desk is typically plain HTTP on a LAN address
  (or 10.0.2.2 from the emulator), so debug builds must allow cleartext to pair
  and talk to it. The release build keeps cleartext blocked; production Front
  Desks are expected to be reached over HTTPS.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:usesCleartextTraffic="true"
        tools:targetApi="28" />

</manifest>
