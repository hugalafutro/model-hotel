# ============================================================
# Front Desk HA stack configuration. Copy to .env and fill in.
#
# Generate strong secrets before deploying:
#   FRONTDESK_TOKEN:      openssl rand -hex 16
#   FRONTDESK_MASTER_KEY: openssl rand -base64 32
#
# FRONTDESK_MASTER_KEY encrypts member admin tokens + the TOTP secret at rest.
# It is independent of each member's MASTER_KEY. Rotating it makes stored member
# tokens unrecoverable (re-enter them in the UI after rotation).
# ============================================================

# Required: the public https:// origin the Front Desk UI is served at (the TLS
# proxy's hostname). Used as the WebAuthn RP ID / expected origin. Front Desk
# refuses to start if unset.
FRONTDESK_PUBLIC_ORIGIN=https://frontdesk.example.com

# Required: AES-256-GCM key for secrets at rest.
FRONTDESK_MASTER_KEY=

# Optional: UI login token. Leave blank to auto-generate and print once to the
# logs on first boot (capture it from `make ha-logs`).
FRONTDESK_TOKEN=

# Optional: the external reverse proxy address(es) (CIDR), comma-separated, so
# real client IPs and HTTPS are read from X-Forwarded-* headers.
FRONTDESK_TRUSTED_PROXIES=

# Host ports. LB_PORT is the client-facing /v1 + dashboard port; FRONTDESK_PORT
# is the admin UI. Front both with the external TLS proxy.
LB_PORT=8080
FRONTDESK_PORT=8090

# Optional: verbose structured logging on Front Desk.
FRONTDESK_DEBUG_LOG=false
