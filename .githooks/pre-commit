#!/bin/sh
#
# Pre-commit hook: run gci import formatting on staged Go files.
# Install with: git config core.hooksPath .githooks
#

set -e

# Only run on Go files
STAGED_GO_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.go')

if [ -z "$STAGED_GO_FILES" ]; then
	exit 0
fi

echo "Running gci import formatting..."

# Run gci on staged Go files
echo "$STAGED_GO_FILES" | xargs gci write -s standard -s default -s "Prefix(github.com/hugalafutro/model-hotel)"

# Re-stage any files that were modified by gci
echo "$STAGED_GO_FILES" | xargs git add

echo "gci formatting applied."