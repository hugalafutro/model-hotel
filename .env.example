# ============================================================
# Required: Generate strong secrets before deploying.
#   MASTER_KEY:       openssl rand -base64 32
#   ADMIN_TOKEN:      openssl rand -hex 16
#   POSTGRES_PASSWORD: openssl rand -hex 16
#
# ⚠️  WARNING: Rotating MASTER_KEY invalidates ALL encrypted
#     provider API keys. Re-encrypt them after rotation.
# ============================================================

MASTER_KEY=
POSTGRES_PASSWORD=

# DATABASE_URL is constructed automatically in docker-compose.yml from
# POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB. Only set this
# if you need to override it (e.g. for local development without Docker).
# For Docker:   postgres://llmproxy:${POSTGRES_PASSWORD}@db:5432/llmproxy
# For local:    postgres://llmproxy:${POSTGRES_PASSWORD}@localhost:5432/llmproxy
# DATABASE_URL=

POSTGRES_USER=llmproxy
POSTGRES_DB=llmproxy
PORT=:8080
DISCOVERY_INTERVAL=30m
DATA_DIR=./data
ADMIN_TOKEN=
ALLOW_HTTP_PROVIDERS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_RPS=30
RATE_LIMIT_IP_BURST=60
MAX_REQUEST_SIZE=10485760
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
ALLOWED_PROVIDER_HOSTS=
TRUSTED_PROXIES=
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5
MODELSDEV_ENABLED=true
DEBUG_LOG=false