# ============================================================
# Required: Generate strong secrets before deploying.
#   MASTER_KEY:       openssl rand -base64 32
#   ADMIN_TOKEN:      openssl rand -hex 16
#   POSTGRES_PASSWORD: openssl rand -hex 16
#
# ⚠️  WARNING: Rotating MASTER_KEY invalidates ALL encrypted
#     provider API keys. Re-encrypt them after rotation.
# ============================================================

MASTER_KEY=
POSTGRES_PASSWORD=

# DATABASE_URL is auto-constructed from POSTGRES_USER, POSTGRES_PASSWORD,
# POSTGRES_HOST, and POSTGRES_DB. Only set it to override the construction
# (e.g. for local development without Docker: localhost instead of db).
# For local dev: DATABASE_URL=postgres://modelhotel:changeme@localhost:5432/modelhotel

POSTGRES_USER=modelhotel
POSTGRES_HOST=db
POSTGRES_DB=modelhotel
# PORT is the Go listen address inside the container (default :8080).
# HOST_PORT is the port exposed on the host machine via Docker (default 8081).
PORT=:8080
HOST_PORT=8081
DISCOVERY_INTERVAL=30m
DATA_DIR=./data
ADMIN_TOKEN=
ALLOW_HTTP_PROVIDERS=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_IP_RPS=30
RATE_LIMIT_IP_BURST=60
MAX_REQUEST_SIZE=10485760
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
ALLOWED_PROVIDER_HOSTS=
TRUSTED_PROXIES=
KNOWN_PROXIES=
DATABASE_MAX_CONNS=25
DATABASE_MIN_CONNS=5
MODELSDEV_ENABLED=true
DEBUG_LOG=false