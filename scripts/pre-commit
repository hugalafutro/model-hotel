#!/usr/bin/env bash
# Pre-commit hook: mirrors CI exactly to catch failures before pushing.
# If it would fail on GitHub, it fails here first.
# Install: cp scripts/pre-commit .git/hooks/pre-commit

set -euo pipefail

# Cleanup temp files on exit
cover_out=""
cover_filtered=""
cleanup() { rm -f "$cover_out" "$cover_filtered"; }
trap cleanup EXIT

echo "pre-commit: mirroring CI checks..."

# ── Go Vet (mirrors ci.yml: go-vet) ──
echo "pre-commit: go vet ./..."
if ! go vet ./...; then
	echo "pre-commit: FAILED - go vet" >&2
	exit 1
fi

# ── golangci-lint (mirrors ci.yml: go-lint) ──
echo "pre-commit: golangci-lint run ./..."
if ! golangci-lint run ./...; then
	echo "pre-commit: FAILED - golangci-lint" >&2
	exit 1
fi

# ── Go Test + Coverage Gate (mirrors ci.yml: go-test) ──
# Single run: coverage profile also catches test failures, no need to run twice.
echo "pre-commit: go test ./... (with coverage)..."
cover_out=$(mktemp)
if ! go test -timeout 5m -coverprofile="$cover_out" -covermode=atomic ./...; then
	echo "pre-commit: FAILED - go test" >&2
	exit 1
fi

# Coverage gate: local-only, stricter than CI.
# Codecov won't fail CI (fail_ci_if_error: false), but we block locally
# to avoid coverage regressions. Mirrors codecov.yml: 80% target, ignores cmd/ tools/.
echo "pre-commit: checking project coverage (mirrors codecov.yml)..."
cover_filtered=$(mktemp)
grep -vE '^github\.com/hugalafutro/model-hotel/(cmd|tools)/' "$cover_out" > "$cover_filtered"
# Re-add mode line from original profile
mode_line=$(head -1 "$cover_out")
if [[ "$mode_line" == mode:* ]]; then
	printf '%s\n' "$mode_line" | cat - "$cover_filtered" > "$cover_filtered.tmp" && mv "$cover_filtered.tmp" "$cover_filtered"
fi
rm -f "$cover_out"

if [ -s "$cover_filtered" ]; then
	pct=$(go tool cover -func="$cover_filtered" 2>/dev/null | tail -1 | awk '{print $NF}' | tr -d '%')
	rm -f "$cover_filtered"
	if [ -z "$pct" ]; then
		echo "pre-commit: WARNING - could not parse coverage, skipping gate"
	else
		pct_int=${pct%%.*}
		if [ "$pct_int" -lt 80 ]; then
			echo "pre-commit: FAILED - project coverage ${pct}% is below 80% threshold" >&2
			echo "  This mirrors codecov.yml — add tests for new code" >&2
			exit 1
		fi
		echo "pre-commit: project coverage ${pct}% (threshold: 80%)"
	fi
else
	rm -f "$cover_filtered"
	echo "pre-commit: WARNING - empty coverage profile, skipping gate"
fi

# ── Frontend Lint (mirrors ci.yml: frontend → pnpm run lint) ──
echo "pre-commit: pnpm lint (web/)..."
if ! (cd web && pnpm run lint); then
	echo "pre-commit: FAILED - pnpm lint" >&2
	exit 1
fi

# ── Frontend Test (mirrors ci.yml: frontend → pnpm vitest run) ──
echo "pre-commit: pnpm vitest run (web/)..."
if ! (cd web && pnpm vitest run); then
	echo "pre-commit: FAILED - pnpm vitest run" >&2
	exit 1
fi

# Note: Vite build is NOT run here per AGENTS.md: "Do NOT run Vite build for pre-commit."
# CI runs it, but it's slow and rarely catches issues the above checks miss.

echo "pre-commit: all checks passed"
