#!/usr/bin/env bash
# Pre-commit: fast formatting only. Real checks run in CI.
# Goal: under 10 seconds, never blocks for slow tests.
#
# Frontend checks (biome) run inside Docker — no local node_modules needed.
# The web/node_modules directory is a 000-permission block to prevent
# accidental local pnpm usage.

set -euo pipefail

# ── Sync check: refuse commits if branch is behind master ──
current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" != "master" ] && [ "$current_branch" != "HEAD" ]; then
	git fetch origin master --quiet 2>/dev/null || true
	behind=$(git rev-list --count HEAD..origin/master 2>/dev/null || echo "0")
	if [ "$behind" -gt 0 ]; then
		echo "" >&2
		echo "⛔ STOP. BRANCH BEHIND MASTER. STOP EVERYTHING." >&2
		echo "" >&2
		echo "DO NOT:" >&2
		echo "  - inspect git history or branches" >&2
		echo "  - edit files" >&2
		echo "  - run any other commands" >&2
		echo "  - attempt to work around this" >&2
		echo "" >&2
		echo "ONLY DO:" >&2
		echo "  git fetch origin && git merge origin/master" >&2
		echo "" >&2
		echo "Then retry the commit. Nothing else." >&2
		echo "" >&2
		exit 1
	fi
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

staged_go=$(git diff --cached --name-only --diff-filter=ACM -- '*.go' || true)
staged_ts=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^web/.*\.tsx?$' || true)

# ── Go: gci import order + go vet on staged packages ──
if [ -n "$staged_go" ]; then
	echo "pre-commit: gci on staged Go files..."
	echo "$staged_go" | xargs gci write -s standard -s default -s "Prefix(github.com/hugalafutro/model-hotel)" >/dev/null
	if ! git diff --quiet -- $staged_go; then
		echo "$staged_go" | xargs git add
		echo "pre-commit: re-staged gci-formatted files"
	fi

	go_pkgs=$(echo "$staged_go" | xargs -n1 dirname | sort -u | sed 's|^|./|; s|$|/...|' | tr '\n' ' ')
	echo "pre-commit: go vet $go_pkgs"
	if ! go vet $go_pkgs; then
		echo "pre-commit: FAILED - go vet" >&2
		exit 1
	fi
fi

# ── Frontend: biome --write on staged TS/TSX (via Docker) ──
if [ -n "$staged_ts" ]; then
	rel_paths=""
	for f in $staged_ts; do
		rel_paths="$rel_paths ${f#web/}"
	done
	echo "pre-commit: biome --write $rel_paths (Docker)"
	if ! docker run --rm \
		-v "$REPO_ROOT/web":/app \
		-w /app \
		node:22-alpine \
		sh -c "npm install -g @biomejs/biome@2.4.16 >/dev/null 2>&1 && biome check --write $rel_paths" >/dev/null 2>&1; then
		echo "pre-commit: FAILED - biome check" >&2
		exit 1
	fi
	# Re-stage any files biome rewrote.
	changed=""
	for f in $staged_ts; do
		if ! git diff --quiet -- "$f"; then
			changed="$changed $f"
		fi
	done
	if [ -n "$changed" ]; then
		git add $changed
		echo "pre-commit: re-staged biome-formatted files: $changed"
	fi
fi

echo "pre-commit: ok"
