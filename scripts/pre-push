#!/usr/bin/env bash
# Pre-push: smoke test only (~30s). GitHub CI is the real gatekeeper.
# If you need to bypass for any reason: git push --no-verify

set -euo pipefail

echo "pre-push: go vet ./..."
if ! go vet ./...; then
	echo "pre-push: FAILED - go vet" >&2
	exit 1
fi

echo "pre-push: pnpm lint (web/)..."
if ! (cd web && pnpm run lint); then
	echo "pre-push: FAILED - pnpm lint" >&2
	exit 1
fi

echo "pre-push: smoke ok"

# ── Auto-tag from .version ──
# After smoke tests pass, ensure the v* tag matching .version exists.
# Pushing the tag also pushes the commit it points to, so the remote stays
# consistent even if the main push hasn't completed yet.
# Skip with: git push --no-verify
version_file=".version"
if [ -f "$version_file" ]; then
	ver=$(tr -d '[:space:]' < "$version_file")
	tag="v${ver}"
	if [ -n "$ver" ] && ! git rev-parse "$tag" >/dev/null 2>&1; then
		echo "pre-push: creating tag $tag (from .version)"
		git tag "$tag"
		remote="${1:-origin}"
		echo "pre-push: pushing tag $tag to $remote"
		git push "$remote" "$tag"
	fi
fi
