#!/usr/bin/env bash
# Pre-push: smoke test (~30s) plus a scoped diff-coverage gate. GitHub CI is
# still the real gatekeeper; this just catches the common failures before a
# wasted CI cycle.
#
# Frontend checks use local pnpm when web/node_modules exists,
# otherwise fall back to Docker.
#
# The diff-coverage gate (mirrors CI's "Coverage Diff Gate") builds coverage
# only for the surfaces whose files changed and fails the push if <90% of this
# branch's changed lines are covered. It runs whole suites, so it can take a
# few minutes; skip it entirely with NO_COVERAGE_PREPUSH=1.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# README/DOCKERHUB.md sync guard - mirrors .github/workflows/dockerhub-readme-guard.yml
# so the "you touched README.md, touch DOCKERHUB.md too" decision happens here
# instead of after a wasted CI cycle. DOCKERHUB.md is the Hub-tailored copy uploaded
# on release. Diff this branch against its merge-base with the default branch (same
# base..head model the CI uses). Set DOCKERHUB_README_NOT_NEEDED=1 to acknowledge a
# README change that genuinely doesn't apply to Docker Hub (local stand-in for the
# 'dockerhub-readme-not-needed' PR label).
DEFAULT_BRANCH="$(git symbolic-ref --quiet --short refs/remotes/origin/HEAD 2>/dev/null | sed 's#^origin/##')"
DEFAULT_BRANCH="${DEFAULT_BRANCH:-master}"
SYNC_BASE="$(git merge-base "origin/${DEFAULT_BRANCH}" HEAD 2>/dev/null || true)"
if [ -n "$SYNC_BASE" ]; then
	CHANGED="$(git diff --name-only "$SYNC_BASE" HEAD)"
	if printf '%s\n' "$CHANGED" | grep -qx "README.md" &&
		! printf '%s\n' "$CHANGED" | grep -qx "DOCKERHUB.md"; then
		if [ "${DOCKERHUB_README_NOT_NEEDED:-}" = "1" ]; then
			echo "pre-push: README.md changed without DOCKERHUB.md - acknowledged (DOCKERHUB_README_NOT_NEEDED=1)"
			echo "  -> CI uses a LABEL, not this env var: add the 'dockerhub-readme-not-needed'" >&2
			echo "     label to the PR or the README/DOCKERHUB.md sync check will re-fail." >&2
		else
			echo "pre-push: FAILED - README.md changed but DOCKERHUB.md did not." >&2
			echo "  Mirror the change into DOCKERHUB.md (the Docker Hub copy), or re-run as" >&2
			echo "  DOCKERHUB_README_NOT_NEEDED=1 git push  if it doesn't apply to Docker Hub" >&2
			echo "  (then add the 'dockerhub-readme-not-needed' label to the PR)." >&2
			exit 1
		fi
	fi
fi

# DOCKERHUB.md length guard - mirrors the 'length' job in dockerhub-readme-guard.yml.
# Docker Hub truncates a repository description at 25,000 characters (sliced
# mid-content, often mid-link), and we never see it locally because the file is
# uploaded verbatim only on release. Guard on chars (Docker Hub's unit) AND bytes
# here so an over-length edit fails before the push, not after a wasted CI cycle.
DOCKERHUB_LIMIT=25000
if [ -f "$REPO_ROOT/DOCKERHUB.md" ]; then
	if command -v python3 >/dev/null 2>&1; then
		DH_CHARS="$(python3 -c "import io,sys; print(len(io.open(sys.argv[1], encoding='utf-8').read()))" "$REPO_ROOT/DOCKERHUB.md")"
	else
		# Fallback: count Unicode characters via wc -m under a UTF-8 locale.
		DH_CHARS="$(LC_ALL=C.UTF-8 wc -m <"$REPO_ROOT/DOCKERHUB.md" | tr -d '[:space:]')"
	fi
	DH_BYTES="$(wc -c <"$REPO_ROOT/DOCKERHUB.md" | tr -d '[:space:]')"
	if [ "$DH_CHARS" -gt "$DOCKERHUB_LIMIT" ] || [ "$DH_BYTES" -gt "$DOCKERHUB_LIMIT" ]; then
		echo "pre-push: FAILED - DOCKERHUB.md is ${DH_CHARS} chars / ${DH_BYTES} bytes, over Docker Hub's ${DOCKERHUB_LIMIT}-char limit." >&2
		echo "  Trim DOCKERHUB.md below ${DOCKERHUB_LIMIT} (it ships to Docker Hub on release and truncates mid-content)." >&2
		exit 1
	fi
fi

echo "pre-push: go vet ./..."
if ! go vet ./cmd/... ./internal/...; then
	echo "pre-push: FAILED - go vet" >&2
	exit 1
fi

echo "pre-push: golangci-lint run ./..."
if ! golangci-lint run ./cmd/... ./internal/...; then
	echo "pre-push: FAILED - golangci-lint" >&2
	exit 1
fi

# tsc -b runs here (not in the Docker image build) so type errors are caught
# locally before push. It is incremental (tsbuildinfo), so it is cheap to repeat.
if [ -d "$REPO_ROOT/web/node_modules" ]; then
	echo "pre-push: pnpm lint + tsc -b (local)..."
	if ! (cd "$REPO_ROOT/web" && pnpm run lint && pnpm exec tsc -b); then
		echo "pre-push: FAILED - pnpm lint / tsc -b" >&2
		exit 1
	fi
else
	echo "pre-push: pnpm lint + tsc -b (Docker)..."
	if ! docker run --rm \
		-v "$REPO_ROOT/web":/app \
		-v model-hotel-pnpm-store:/pnpm/store \
		--tmpfs /app/node_modules:exec \
		-e PNPM_HOME=/root/.local/share/pnpm \
		-w /app \
		node:22-alpine \
		sh -c "npm install -g pnpm@10 >/dev/null 2>&1 && pnpm config set store-dir /pnpm/store >/dev/null && pnpm install --frozen-lockfile >/dev/null 2>&1 && pnpm run lint && pnpm exec tsc -b" 2>&1; then
		echo "pre-push: FAILED - pnpm lint / tsc -b" >&2
		exit 1
	fi
fi

# Scoped diff-coverage gate. Only builds coverage for changed surfaces; blocks
# the push if changed lines fall below 90%. Go coverage needs the test Postgres
# on :5433 - if it's not up, Go is skipped with a warning (CI still enforces it)
# rather than blocking. Bypass the whole gate with NO_COVERAGE_PREPUSH=1.
if [ "${NO_COVERAGE_PREPUSH:-}" = "1" ]; then
	echo "pre-push: diff-coverage gate skipped (NO_COVERAGE_PREPUSH=1)"
elif [ -z "$SYNC_BASE" ]; then
	echo "pre-push: diff-coverage gate skipped (no merge-base with origin/${DEFAULT_BRANCH})" >&2
elif ! command -v python3 >/dev/null 2>&1; then
	echo "pre-push: diff-coverage gate skipped (python3 not found)" >&2
else
	CHANGED_FILES="$(git diff --name-only "$SYNC_BASE" HEAD)"
	COV_DIR="$(mktemp -d)"
	trap 'rm -rf "$COV_DIR"' EXIT
	DC_ARGS=()

	# Go: any non-test .go under internal/ (cmd/ and tools/ are excluded from coverage).
	if printf '%s\n' "$CHANGED_FILES" | grep -E '^internal/.*\.go$' | grep -qvE '_test\.go$'; then
		if (exec 3<>/dev/tcp/localhost/5433) 2>/dev/null; then
			echo "pre-push: coverage - go test ./internal/... (Postgres :5433 up)"
			if go test -timeout 5m -coverprofile="$COV_DIR/go.out" -covermode=atomic ./internal/...; then
				DC_ARGS+=(--go "$COV_DIR/go.out")
			else
				echo "pre-push: FAILED - go test (coverage run)" >&2
				exit 1
			fi
		else
			echo "pre-push: WARNING - test Postgres on :5433 not up; skipping Go diff-coverage (CI still enforces it)." >&2
		fi
	fi

	# web dashboard frontend.
	if printf '%s\n' "$CHANGED_FILES" | grep -qE '^web/src/'; then
		echo "pre-push: coverage - web vitest"
		if (cd "$REPO_ROOT/web" && env -u NODE_ENV pnpm exec vitest run --coverage --coverage.reporter=lcov); then
			DC_ARGS+=(--lcov "web/=$REPO_ROOT/web/coverage/lcov.info")
		else
			echo "pre-push: FAILED - web vitest (coverage run)" >&2
			exit 1
		fi
	fi

	# Front Desk frontend.
	if printf '%s\n' "$CHANGED_FILES" | grep -qE '^frontdesk/web/src/'; then
		echo "pre-push: coverage - frontdesk/web vitest"
		if (cd "$REPO_ROOT/frontdesk/web" && env -u NODE_ENV pnpm exec vitest run --coverage --coverage.reporter=lcov); then
			DC_ARGS+=(--lcov "frontdesk/web/=$REPO_ROOT/frontdesk/web/coverage/lcov.info")
		else
			echo "pre-push: FAILED - frontdesk/web vitest (coverage run)" >&2
			exit 1
		fi
	fi

	if [ "${#DC_ARGS[@]}" -eq 0 ]; then
		echo "pre-push: diff-coverage gate - no measurable changed surfaces, skipping"
	else
		echo "pre-push: diff-coverage gate (threshold 90%)..."
		if ! (cd "$REPO_ROOT" && python3 scripts/coverage/diff_coverage.py --diff-base "$SYNC_BASE" "${DC_ARGS[@]}"); then
			echo "pre-push: FAILED - diff coverage below 90% on changed lines." >&2
			echo "  Add tests for the uncovered changed lines, or re-run as" >&2
			echo "  NO_COVERAGE_PREPUSH=1 git push  to bypass the gate." >&2
			exit 1
		fi
	fi
fi

echo "pre-push: smoke ok (full CI runs on GitHub)"
